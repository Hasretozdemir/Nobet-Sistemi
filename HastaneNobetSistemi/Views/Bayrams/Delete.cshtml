@model HastaneNobetSistemi.Models.Bayram

@{
    ViewData["Title"] = "Bayram Sil";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-4 border-top border-danger border-5">

            <div class="card-body p-4 p-md-5 text-center">

                <div class="text-danger mb-4">
                    <i class="fa-solid fa-triangle-exclamation fa-4x mb-3 animation-pulse"></i>
                    <h3 class="fw-bold">Kaydı Silmek Üzeresiniz!</h3>
                    <p class="text-muted">Bu tatil/bayram tanımını silmek istediğinize emin misiniz? Bu işlem geri alınamaz ve otomatik nöbet dağılımındaki puan hesaplamalarını etkileyebilir.</p>
                </div>

                <div class="bg-light rounded-3 p-4 text-start mb-4 shadow-sm border">
                    <h5 class="fw-bold border-bottom pb-2 mb-3 text-secondary">
                        <i class="fa-solid fa-calendar-xmark me-2"></i>Silinecek Kayıt Detayları
                    </h5>

                    <div class="row mb-2 align-items-center">
                        <div class="col-sm-5 fw-semibold text-muted">
                            <i class="fa-solid fa-tag me-2"></i>@Html.DisplayNameFor(model => model.BayramAdi)
                        </div>
                        <div class="col-sm-7 fw-bold text-dark fs-5">
                            @Html.DisplayFor(model => model.BayramAdi)
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-5 fw-semibold text-muted">
                            <i class="fa-solid fa-hourglass-start me-2"></i>@Html.DisplayNameFor(model => model.BaslangicTarihi)
                        </div>
                        <div class="col-sm-7 fw-bold text-dark">
                            @Html.DisplayFor(model => model.BaslangicTarihi)
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-5 fw-semibold text-muted">
                            <i class="fa-solid fa-hourglass-end me-2"></i>@Html.DisplayNameFor(model => model.BitisTarihi)
                        </div>
                        <div class="col-sm-7 fw-bold text-dark">
                            @Html.DisplayFor(model => model.BitisTarihi)
                        </div>
                    </div>
                </div>

                <form asp-action="Delete" class="d-flex justify-content-between mt-4">
                    <input type="hidden" asp-for="Id" />

                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 transition-hover">
                        <i class="fa-solid fa-arrow-left me-2"></i>Vazgeç
                    </a>

                    <button type="submit" class="btn btn-danger px-4 py-2 fw-bold rounded-3 shadow-sm">
                        <i class="fa-solid fa-trash-can me-2"></i>Evet, Kalıcı Olarak Sil
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        /* Hafif bir yanıp sönme animasyonu ekleyerek dikkati artırıyoruz */
        .animation-pulse {
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
    </style>
}