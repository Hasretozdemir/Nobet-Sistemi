@model HastaneNobetSistemi.Models.Bayram

@{
    ViewData["Title"] = "Bayram Detayları";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-header bg-info text-white text-center py-4 rounded-top-4">
                <i class="fa-solid fa-calendar-day fa-3x mb-2 opacity-75"></i>
                <h3 class="mb-0 fw-bold">Tatil / Bayram Detayları</h3>
            </div>

            <div class="card-body p-4 p-md-5">

                <ul class="list-group list-group-flush fs-5 mb-4">
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-tag me-2 text-info"></i>@Html.DisplayNameFor(model => model.BayramAdi)
                        </span>
                        <span class="fw-bold text-dark text-end">
                            @Html.DisplayFor(model => model.BayramAdi)
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-hourglass-start me-2 text-info"></i>@Html.DisplayNameFor(model => model.BaslangicTarihi)
                        </span>
                        <span class="fw-bold text-dark text-end">
                            @Html.DisplayFor(model => model.BaslangicTarihi)
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-hourglass-end me-2 text-info"></i>@Html.DisplayNameFor(model => model.BitisTarihi)
                        </span>
                        <span class="fw-bold text-dark text-end">
                            @Html.DisplayFor(model => model.BitisTarihi)
                        </span>
                    </li>
                </ul>

                <div class="d-flex justify-content-between align-items-center mt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3">
                        <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-5 py-2 fw-bold rounded-3 shadow-sm text-dark">
                        <i class="fa-solid fa-pen-to-square me-2"></i>Düzenle
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>