@model IEnumerable<HastaneNobetSistemi.Models.Bayram>

@{
    ViewData["Title"] = "Bayram ve Tatil Listesi";
}

<div class="container mt-4 mb-5">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h5 class="fw-bold text-dark mb-0" style="letter-spacing: -0.5px;">
                <span class="text-primary opacity-75">#</span> Tatil Takvimi
            </h5>
            <span class="text-muted" style="font-size: 0.75rem;">Toplam @Model.Count() kayıt tanımlı</span>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary btn-sm rounded-2 px-3 fw-semibold shadow-sm border-0">
                <i class="fa-solid fa-plus me-1" style="font-size: 0.7rem;"></i> Yeni Ekle
            </a>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-3">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="border rounded-3 p-4 text-center bg-white shadow-sm">
                    <p class="text-muted small mb-0">Henüz bir tatil kaydı bulunmuyor.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-3 compact-card">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="mini-tag bg-primary"></div>
                                    <h6 class="fw-bold text-dark mb-0" style="font-size: 0.9rem;">@item.BayramAdi</h6>
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0 border-0" data-bs-toggle="dropdown">
                                        <i class="fa-solid fa-ellipsis-vertical small"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3" style="font-size: 0.8rem;">
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="fa-solid fa-pen me-2"></i>Düzenle</a></li>
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="fa-solid fa-eye me-2"></i>Detay</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="fa-solid fa-trash me-2"></i>Sil</a></li>
                                    </ul>
                                </div>
                            </div>

                            <div class="mt-3 d-flex align-items-center gap-2 text-muted" style="font-size: 0.8rem;">
                                <div class="flex-fill bg-light rounded-2 px-2 py-1 border-start border-primary border-3">
                                    <span class="d-block fw-bold text-dark" style="font-size: 0.65rem; opacity: 0.6;">BAŞLANGIÇ</span>
                                    <span>@item.BaslangicTarihi.ToString("dd.MM.yyyy")</span>
                                </div>
                                <i class="fa-solid fa-arrow-right-long opacity-25"></i>
                                <div class="flex-fill bg-light rounded-2 px-2 py-1 border-start border-info border-3">
                                    <span class="d-block fw-bold text-dark" style="font-size: 0.65rem; opacity: 0.6;">BİTİŞ</span>
                                    <span>@item.BitisTarihi.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <style>
        body {
            background-color: #f4f7f9;
        }

        /* Kart Boyut ve Stil Ayarları */
        .compact-card {
            background-color: #ffffff;
            transition: all 0.2s ease-in-out;
            border: 1px solid rgba(0,0,0,0.02) !important;
        }

            .compact-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
            }

        /* Başlık Yanındaki Küçük Şerit */
        .mini-tag {
            width: 4px;
            height: 16px;
            border-radius: 2px;
        }

        /* Dropdown Butonu Temizliği */
        .btn-link:focus {
            box-shadow: none;
        }

        .dropdown-item {
            padding: 8px 16px;
            transition: all 0.2s;
        }

            .dropdown-item:hover {
                background-color: #f8f9fa;
            }

        /* Mobil Uyumluluk */
        @@media (max-width: 576px) {
            h5 {
                font-size: 1rem;
            }

            .compact-card {
                padding: 10px;
            }
        }
    </style>
}