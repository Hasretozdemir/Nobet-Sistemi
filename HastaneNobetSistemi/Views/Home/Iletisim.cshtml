@{
    ViewData["Title"] = "Ýletiţim & Geri Bildirim";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="container py-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["MailtoLink"] != null)
    {
        <script>window.location.href = "@Html.Raw(TempData["MailtoLink"])";</script>
    }

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">

            <!-- HEADER -->
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
                <div class="card-header py-4 px-4 border-0 position-relative" style="background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);">
                    <div class="d-flex align-items-center justify-content-between position-relative" style="z-index: 2;">
                        <div>
                            <h3 class="text-white mb-0 fw-bold">
                                <i class="fa-solid fa-envelope me-2 text-warning"></i>Ýletiţim & Geri Bildirim
                            </h3>
                            <p class="text-white-50 small mb-0 mt-1">Hata bildirimi, öneri veya sorularýnýz için bize ulaţýn.</p>
                        </div>
                        <div class="text-white-50 d-none d-sm-block">
                            <i class="fa-solid fa-headset fa-3x opacity-25"></i>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5" style="background: #f4f7fe;">

                    <!-- Geliţtirici Bilgisi -->
                    <div class="d-flex align-items-center p-4 bg-white rounded-4 shadow-sm mb-4 border-start border-4 border-primary">
                        <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center rounded-circle me-4" style="width:55px;height:55px;">
                            <i class="fa-solid fa-code text-primary fs-4"></i>
                        </div>
                        <div>
                            <small class="text-muted text-uppercase fw-bold">Geliţtirici</small>
                            <h5 class="fw-bold text-dark mb-0">Hasret Özdemir</h5>
                            <small class="text-muted">Gazi Üniversitesi · Bilgisayar Mühendisliđi</small>
                        </div>
                    </div>

                    <!-- Kategori Kartlarý -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3 kategori-card" onclick="selectKategori('Hata Bildirimi', this)" style="cursor:pointer; transition: all 0.2s;">
                                <div class="mx-auto mb-2 d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:rgba(239,68,68,0.1);">
                                    <i class="fa-solid fa-bug text-danger fs-5"></i>
                                </div>
                                <small class="fw-bold text-dark">Hata Bildirimi</small>
                                <small class="text-muted d-block" style="font-size:0.7rem;">Sistemde bir sorun mu var?</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3 kategori-card" onclick="selectKategori('Öneri', this)" style="cursor:pointer; transition: all 0.2s;">
                                <div class="mx-auto mb-2 d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:rgba(67,97,238,0.1);">
                                    <i class="fa-solid fa-lightbulb text-primary fs-5"></i>
                                </div>
                                <small class="fw-bold text-dark">Öneri</small>
                                <small class="text-muted d-block" style="font-size:0.7rem;">Geliţtirilmesini ister misiniz?</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 text-center p-3 kategori-card" onclick="selectKategori('Genel Soru', this)" style="cursor:pointer; transition: all 0.2s;">
                                <div class="mx-auto mb-2 d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:rgba(16,185,129,0.1);">
                                    <i class="fa-solid fa-circle-question text-success fs-5"></i>
                                </div>
                                <small class="fw-bold text-dark">Genel Soru</small>
                                <small class="text-muted d-block" style="font-size:0.7rem;">Merak ettiklerinizi sorun</small>
                            </div>
                        </div>
                    </div>

                    <!-- Ýletiţim Formu -->
                    <form asp-action="Iletisim" method="post">
                        <input type="hidden" name="Kategori" id="kategoriInput" value="Genel Soru" />

                        <div class="form-floating shadow-sm rounded-3 mb-3">
                            <input type="text" name="Konu" class="form-control border-0 px-4" placeholder="Konu" required maxlength="200" />
                            <label class="text-muted"><i class="fa-solid fa-heading me-2 text-primary"></i>Konu Baţlýđý</label>
                        </div>

                        <div class="form-floating shadow-sm rounded-3 mb-4">
                            <textarea name="Mesaj" class="form-control border-0 px-4" placeholder="Mesajýnýz" style="height: 150px" required maxlength="2000"></textarea>
                            <label class="text-muted"><i class="fa-solid fa-pen me-2 text-primary"></i>Mesajýnýz</label>
                        </div>

                        <div class="alert alert-info border-0 rounded-3 shadow-sm mb-4">
                            <i class="fa-solid fa-circle-info me-2"></i>
                            <strong>Not:</strong> Gönder'e bastýđýnýzda mail uygulamanýz açýlacak ve hazýrlanmýţ mesajý dođrudan gönderebileceksiniz.
                            <strong>@User.Identity?.Name</strong> olarak gönderilecektir.
                        </div>

                        <button type="submit" class="btn w-100 py-3 rounded-pill fw-bold shadow text-white" style="background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%); transition: all 0.3s;">
                            <i class="fa-solid fa-paper-plane me-2"></i>Mesajý Hazýrla ve Gönder
                        </button>
                    </form>
                </div>
            </div>

            <!-- Hýzlý Ýletiţim Kartlarý -->
            <div class="row g-3">
                <div class="col-md-6">
                    <a href="mailto:hasretozdemir288@gmail.com" class="card border-0 shadow-sm rounded-4 p-4 text-decoration-none h-100 iletisim-card" style="transition: all 0.2s;">
                        <div class="d-flex align-items-center">
                            <div class="bg-danger bg-opacity-10 d-flex align-items-center justify-content-center rounded-3 me-3" style="width:48px;height:48px;">
                                <i class="fa-solid fa-envelope text-danger fs-5"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block fw-bold">E-posta</small>
                                <span class="text-dark fw-bold small">hasretozdemir288@gmail.com</span>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="https://github.com/Hasretozdemir/Nobet-Sistemi/issues" target="_blank" class="card border-0 shadow-sm rounded-4 p-4 text-decoration-none h-100 iletisim-card" style="transition: all 0.2s;">
                        <div class="d-flex align-items-center">
                            <div class="bg-dark bg-opacity-10 d-flex align-items-center justify-content-center rounded-3 me-3" style="width:48px;height:48px;">
                                <i class="fa-brands fa-github text-dark fs-5"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block fw-bold">GitHub Issues</small>
                                <span class="text-dark fw-bold small">Hata & Özellik Talebi</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectKategori(kategori, element) {
            document.getElementById('kategoriInput').value = kategori;
            document.querySelectorAll('.kategori-card').forEach(c => {
                c.style.border = 'none';
                c.style.background = '#fff';
            });
            element.style.border = '2px solid #4361ee';
            element.style.background = '#eef2ff';
        }
    </script>
    <style>
        .iletisim-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.08) !important; }
        .kategori-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.08) !important; }
        .form-control:focus { box-shadow: none; border: 1px solid #4361ee !important; }
        .form-floating > .form-control { border-bottom: 2px solid transparent; }
        .form-floating > .form-control:focus { border-bottom: 2px solid #4361ee; }
    </style>
}
