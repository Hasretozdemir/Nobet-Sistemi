@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-4">

    <!-- SİSTEM BİLDİRİMLERİ -->
    @if (ViewContext.HttpContext.Request.Cookies["dismissedDevNotice"] == null)
    {
        <div class="alert border-0 shadow-sm rounded-4 mb-4 p-0 overflow-hidden" id="devNoticeAlert" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);">
            <div class="d-flex align-items-start p-4">
                <div class="me-3 mt-1">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:rgba(245,158,11,0.2);">
                        <i class="fa-solid fa-triangle-exclamation text-warning fs-4"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-1"><i class="fa-solid fa-code me-2"></i>Geliştirici Notu</h6>
                    <p class="text-dark mb-2 small" style="line-height: 1.7;">
                        Bu sistem <strong>yeni mezun bir geliştirici  </strong> tarafından geliştirilmiş olup henüz <strong>aktif geliştirme aşamasındadır</strong>.
                        Nöbet dağıtımlarını ve listeleri lütfen <strong>kontrollü bir şekilde</strong> yapınız.
                        Herhangi bir hata, eksiklik veya beklenmedik davranış fark ettiğinizde
                        <a asp-controller="Home" asp-action="Iletisim" class="fw-bold text-warning text-decoration-underline">İletişim sayfasından</a>
                        geliştirici ile iletişime geçmenizi rica ederiz.
                    </p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-controller="Home" asp-action="Iletisim" class="btn btn-sm btn-warning rounded-pill px-3 fw-bold shadow-sm">
                            <i class="fa-solid fa-envelope me-1"></i> Hata Bildir
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-dark rounded-pill px-3" onclick="dismissNotice('devNotice')">
                            <i class="fa-solid fa-check me-1"></i> Anladım, Kapat
                        </button>
                    </div>
                </div>
                <button type="button" class="btn-close ms-2" onclick="dismissNotice('devNotice')"></button>
            </div>
        </div>
    }

    @if (ViewContext.HttpContext.Request.Cookies["dismissedSystemInfo"] == null)
    {
        <div class="alert border-0 shadow-sm rounded-4 mb-4 p-0 overflow-hidden" id="systemInfoAlert" style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);">
            <div class="d-flex align-items-start p-4">
                <div class="me-3 mt-1">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:rgba(59,130,246,0.15);">
                        <i class="fa-solid fa-circle-info text-primary fs-4"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-1"><i class="fa-solid fa-laptop-medical me-2"></i>Sistem Hakkında</h6>
                    <p class="text-dark mb-2 small" style="line-height: 1.7;">
                        <strong>Hastane Nöbet Dağıtım Otomasyonu</strong>, Bilgi İşlem Birimi personellerinin nöbet planlamasını
                        <strong>adil ve otomatik</strong> olarak gerçekleştirir.
                        Sistem; hafta içi/hafta sonu/bayram nöbet tiplerini algılar, 7 günlük dinlenme kuralı uygular,
                        izinli personeli otomatik muaf tutar ve <strong>Excel çıktısı</strong> üretir.
                        Personeller kendi aralarında <strong>takas</strong> yapabilir ve <strong>izin talebi</strong> oluşturabilir.
                    </p>
                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="dismissNotice('systemInfo')">
                        <i class="fa-solid fa-check me-1"></i> Anladım
                    </button>
                </div>
                <button type="button" class="btn-close ms-2" onclick="dismissNotice('systemInfo')"></button>
            </div>
        </div>
    }

    <div class="main-hero p-4 p-md-5 mb-4 bg-white rounded-4 shadow-sm border-0 text-center position-relative overflow-hidden">
        <div class="position-relative" style="z-index: 1;">
            <div class="icon-circle mb-3">
                <i class="fa-solid fa-laptop-medical fa-2x text-primary"></i>
            </div>

            <h1 class="h2 fw-bold text-dark mb-2">Nöbet Dağıtım Otomasyonu</h1>
            <p class="mx-auto text-muted mb-4 custom-lead">
                Adil puanlama algoritması ile personellerin hafta içi, hafta sonu ve bayram nöbetlerini şeffaf ve hatasız yönetin.
            </p>

            <div class="d-flex justify-content-center gap-2 mt-2 flex-wrap">
                <a asp-controller="Nobets" asp-action="Index" class="btn custom-btn btn-primary px-4">
                    <i class="fa-solid fa-calendar-days me-2"></i>Nöbet Takvimi
                </a>
                <a asp-controller="Personels" asp-action="Index" class="btn custom-btn btn-outline-secondary px-4">
                    <i class="fa-solid fa-users-gear me-2"></i>Personeller
                </a>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100 feature-card shadow-sm border-0 rounded-4">
                <div class="card-body text-center p-4">
                    <div class="mini-icon-circle bg-primary-light text-primary mb-3">
                        <i class="fa-solid fa-user-doctor"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Personel Yönetimi</h5>
                    <p class="text-muted small">Kayıtlı personelleri, aktiflik durumlarını ve puan geçmişlerini takip edin.</p>
                    <a asp-controller="Personels" asp-action="Index" class="btn btn-sm btn-link text-decoration-none fw-bold mt-2">
                        Listeye Git <i class="fa-solid fa-chevron-right ms-1 small"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 feature-card shadow-sm border-0 rounded-4">
                <div class="card-body text-center p-4">
                    <div class="mini-icon-circle bg-success-light text-success mb-3">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Adil Dağıtım</h5>
                    <p class="text-muted small">Tatil ve bayram katsayılarıyla en adil nöbet atamasını saniyeler içinde yapın.</p>
                    <span class="badge bg-success bg-opacity-10 text-success fw-medium rounded-pill px-3 py-2 mt-3">
                        <i class="fa-solid fa-check-circle me-1"></i> Algoritma Aktif
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 feature-card shadow-sm border-0 rounded-4">
                <div class="card-body text-center p-4">
                    <div class="mini-icon-circle bg-warning-light text-warning mb-3">
                        <i class="fa-solid fa-umbrella-beach"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Tatil & Bayramlar</h5>
                    <p class="text-muted small">Bayram nöbetlerini ayırmak için özel tarihleri ve resmi tatilleri tanımlayın.</p>
                    <a asp-controller="Bayrams" asp-action="Index" class="btn btn-sm btn-link text-decoration-none fw-bold mt-2 text-warning">
                        Tanımlara Git <i class="fa-solid fa-chevron-right ms-1 small"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function dismissNotice(type) {
            var cookieName = 'dismissed' + type.charAt(0).toUpperCase() + type.slice(1);
            document.cookie = cookieName + "=true; path=/; max-age=" + (30 * 24 * 60 * 60);
            var alertId = type === 'devNotice' ? 'devNoticeAlert' : 'systemInfoAlert';
            var el = document.getElementById(alertId);
            if (el) {
                el.style.transition = 'opacity 0.3s, transform 0.3s';
                el.style.opacity = '0';
                el.style.transform = 'translateY(-10px)';
                setTimeout(function () { el.remove(); }, 300);
            }
        }
    </script>

    <style>
        :root {
            --primary-light: #eff6ff;
            --success-light: #f0fdf4;
            --warning-light: #fffbeb;
        }

        body {
            background-color: #f8fafc;
        }

        .main-hero {
            background: #ffffff !important;
            border-bottom: 3px solid #3b82f6 !important;
        }

        .custom-lead {
            max-width: 600px;
            font-size: 1rem;
            line-height: 1.5;
        }

        .icon-circle {
            width: 64px;
            height: 64px;
            background: var(--primary-light);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .mini-icon-circle {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin: 0 auto;
        }

        .bg-primary-light {
            background-color: var(--primary-light);
        }

        .bg-success-light {
            background-color: var(--success-light);
        }

        .bg-warning-light {
            background-color: var(--warning-light);
        }

        .feature-card {
            transition: all 0.25s ease;
        }

            .feature-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
            }

        .custom-btn {
            padding: 10px 24px;
            font-size: 0.9rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.2s;
        }

            .custom-btn:hover {
                transform: translateY(-1px);
            }

        @@media (max-width: 768px) {
            h1.h2 {
                font-size: 1.4rem;
            }

            .custom-lead {
                font-size: 0.9rem;
            }

            .custom-btn {
                width: 100%;
            }
        }
    </style>
}