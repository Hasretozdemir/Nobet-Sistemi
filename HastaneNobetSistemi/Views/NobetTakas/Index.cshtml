@{
    ViewData["Title"] = "Nöbet Takas Sistemi";
    var personel = ViewBag.Personel as HastaneNobetSistemi.Models.Personel;
    var benimTekliflerim = ViewBag.BenimTekliflerim as List<HastaneNobetSistemi.Models.NobetTakas>;
    var banaGelenTeklifler = ViewBag.BanaGelenTeklifler as List<HastaneNobetSistemi.Models.NobetTakas>;
    var onaylananTakaslarim = ViewBag.OnaylananTakaslarim as List<HastaneNobetSistemi.Models.NobetTakas>;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f7fe; }
    .glass-header { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); }
    .custom-card { border: none; border-radius: 20px; transition: transform 0.2s; }
    .custom-card:hover { transform: translateY(-3px); }
    .status-badge { padding: 6px 14px; border-radius: 10px; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .incoming-offer { border-left: 5px solid #198754 !important; border-radius: 16px; }
    .swap-agreed { border-left: 5px solid #4361ee !important; border-radius: 16px; }
    .table thead th { background-color: #f1f4f8; color: #4a5568; font-weight: 600; border: none; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .transition-all { transition: all 0.3s ease; }
    .transition-all:hover { transform: translateY(-2px); box-shadow: 0 8px 16px rgba(0,0,0,0.1) !important; }
</style>

<div class="container py-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
            <i class="fa-solid fa-circle-info me-2"></i> @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- HEADER -->
    <div class="glass-header p-5 mb-5 text-white d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="display-6 fw-bold mb-2"><i class="fa-solid fa-arrows-rotate me-3"></i>Nöbet Takas Merkezi</h1>
            <p class="opacity-75 mb-0"><i class="fa-solid fa-circle-info me-2"></i>Nöbet takasları resmi listeyi etkilemez. Kendi aranızda anlaşarak nöbet günlerinizi değiştirebilirsiniz.</p>
        </div>
        <a asp-action="Create" class="btn btn-light btn-lg rounded-pill px-4 fw-bold shadow transition-all">
            <i class="fa-solid fa-plus me-2 text-primary"></i>Yeni Takas Oluştur
        </a>
    </div>

    <!-- BANA GELEN TEKLİFLER -->
    <div class="card custom-card shadow-sm mb-4">
        <div class="card-header bg-white py-3 px-4 border-0 rounded-top-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-dark">
                    <i class="fa-solid fa-inbox me-2 text-success"></i>Bana Gelen Teklifler
                </h5>
                @if (banaGelenTeklifler?.Any() == true)
                {
                    <span class="badge rounded-pill bg-danger shadow-sm px-3 py-2">@banaGelenTeklifler.Count Yeni</span>
                }
            </div>
        </div>
        <div class="card-body p-4">
            @if (banaGelenTeklifler == null || !banaGelenTeklifler.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-inbox fs-1 text-muted opacity-25 d-block mb-3"></i>
                    <p class="text-muted">Şu an için bekleyen bir teklifiniz bulunmuyor.</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var teklif in banaGelenTeklifler)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100 border shadow-sm incoming-offer">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center rounded-circle me-3" style="width:45px;height:45px;">
                                            <i class="fa-solid fa-user-doctor text-primary fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold">@teklif.TeklifEdenPersonel?.AdSoyad</h6>
                                            <small class="text-muted">@teklif.OlusturmaTarihi.ToString("dd MMM yyyy, HH:mm")</small>
                                        </div>
                                    </div>
                                    <div class="bg-light rounded-3 p-3 mb-3">
                                        <div class="small text-muted mb-1">Takas etmek istediği nöbet:</div>
                                        <div class="fw-bold">@teklif.TeklifEdilenNobet?.Tarih.ToString("dd MMMM yyyy dddd")</div>
                                        @if (teklif.TeklifEdilenNobet != null)
                                        {
                                            <span class="badge @(teklif.TeklifEdilenNobet.NobetTipi == "HaftaSonu" ? "bg-warning text-dark" : teklif.TeklifEdilenNobet.NobetTipi == "Bayram" ? "bg-info" : "bg-secondary") mt-2">@teklif.TeklifEdilenNobet.NobetTipi</span>
                                        }
                                    </div>
                                    <p class="small text-secondary mb-4 fst-italic border-start border-3 border-primary ps-3">"@teklif.Aciklama"</p>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Accept" asp-route-id="@teklif.Id" class="btn btn-success flex-grow-1 rounded-pill fw-bold transition-all">
                                            <i class="fa-solid fa-check me-1"></i> Kabul Et
                                        </a>
                                        <button class="btn btn-outline-danger flex-grow-1 rounded-pill fw-bold transition-all" data-bs-toggle="modal" data-bs-target="#redModal-@teklif.Id">
                                            <i class="fa-solid fa-xmark me-1"></i> Reddet
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Red Modal -->
                        <div class="modal fade" id="redModal-@teklif.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content rounded-4 border-0 shadow-lg">
                                    <div class="modal-header bg-danger text-white border-0 rounded-top-4 py-3">
                                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-ban me-2"></i>Teklifi Reddet</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form asp-action="Reject" method="post">
                                        <div class="modal-body p-4">
                                            <input type="hidden" name="id" value="@teklif.Id" />
                                            <p class="text-muted mb-3"><strong>@teklif.TeklifEdenPersonel?.AdSoyad</strong> tarafından gelen teklifi reddetmek üzeresiniz.</p>
                                            <div class="form-floating">
                                                <textarea name="redNedeni" class="form-control border-0 bg-light" placeholder="Red nedeni" style="height: 100px"></textarea>
                                                <label class="text-muted"><i class="fa-solid fa-comment me-2"></i>Red Nedeni (İsteğe Bağlı)</label>
                                            </div>
                                        </div>
                                        <div class="modal-footer border-0 p-4 pt-0">
                                            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                                            <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                                                <i class="fa-solid fa-ban me-1"></i> Reddet
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ONAYLANAN TAKASLARIM -->
    @if (onaylananTakaslarim?.Any() == true)
    {
        <div class="card custom-card shadow-sm mb-4">
            <div class="card-header bg-white py-3 px-4 border-0 rounded-top-4">
                <h5 class="mb-0 fw-bold text-dark">
                    <i class="fa-solid fa-handshake me-2 text-primary"></i>Anlaşılan Takaslarım
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill ms-2 px-3">@onaylananTakaslarim.Count</span>
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info border-0 rounded-3 shadow-sm mb-4">
                    <i class="fa-solid fa-circle-info me-2"></i>
                    Bu takaslar resmi nöbet listesini <strong>etkilemez</strong>. Takas edilen günlerde birbirinizin yerine nöbet tutacaksınız.
                </div>
                <div class="row g-3">
                    @foreach (var takas in onaylananTakaslarim)
                    {
                        var benTeklifEttim = takas.TeklifEdenPersonelId == personel?.Id;
                        var digerKisi = benTeklifEttim ? takas.KabulEdenPersonel : takas.TeklifEdenPersonel;
                        var benimNobetim = benTeklifEttim ? takas.TeklifEdilenNobet : takas.KarsilikNobet;
                        var onunNobeti = benTeklifEttim ? takas.KarsilikNobet : takas.TeklifEdilenNobet;

                        <div class="col-md-6">
                            <div class="card h-100 border shadow-sm swap-agreed">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center justify-content-between mb-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center rounded-circle me-3" style="width:40px;height:40px;">
                                                <i class="fa-solid fa-handshake text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">@digerKisi?.AdSoyad ile Takas</h6>
                                                <small class="text-muted">@takas.YanitTarihi?.ToString("dd MMM yyyy")</small>
                                            </div>
                                        </div>
                                        <span class="status-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">Anlaşıldı</span>
                                    </div>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="bg-danger bg-opacity-10 rounded-3 p-3 text-center">
                                                <small class="d-block text-danger fw-bold mb-1"><i class="fa-solid fa-arrow-right-from-bracket me-1"></i>Verdiğim</small>
                                                <div class="fw-bold text-dark small">@benimNobetim?.Tarih.ToString("dd MMM yyyy")</div>
                                                <div class="text-muted" style="font-size:0.7rem;">@benimNobetim?.Tarih.ToString("dddd")</div>
                                                @if (personel?.NobetUcreti > 0)
                                                {
                                                    <span class="badge bg-danger bg-opacity-25 text-danger mt-1" style="font-size:0.65rem;">-@personel.NobetUcreti.ToString("N2") ₺</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="bg-success bg-opacity-10 rounded-3 p-3 text-center">
                                                <small class="d-block text-success fw-bold mb-1"><i class="fa-solid fa-arrow-right-to-bracket me-1"></i>Aldığım</small>
                                                <div class="fw-bold text-dark small">@onunNobeti?.Tarih.ToString("dd MMM yyyy")</div>
                                                <div class="text-muted" style="font-size:0.7rem;">@onunNobeti?.Tarih.ToString("dddd")</div>
                                                @if (personel?.NobetUcreti > 0)
                                                {
                                                    <span class="badge bg-success bg-opacity-25 text-success mt-1" style="font-size:0.65rem;">+@personel.NobetUcreti.ToString("N2") ₺</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- GÖNDERDİĞİM TEKLİFLER -->
    <div class="card custom-card shadow-sm">
        <div class="card-header bg-white py-3 px-4 border-0 rounded-top-4">
            <h5 class="mb-0 fw-bold text-dark">
                <i class="fa-solid fa-paper-plane me-2 text-primary"></i>Gönderdiğim Teklifler
            </h5>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Nöbet Detayı</th>
                            <th>Hedef Kişi</th>
                            <th>Durum</th>
                            <th>Tarih</th>
                            <th class="text-end pe-4">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (benimTekliflerim != null && benimTekliflerim.Any())
                        {
                            @foreach (var teklif in benimTekliflerim)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="fw-bold text-dark">@teklif.TeklifEdilenNobet?.Tarih.ToString("dd MMM yyyy dddd")</div>
                                        <span class="badge @(teklif.TeklifEdilenNobet?.NobetTipi == "HaftaSonu" ? "bg-warning text-dark" : teklif.TeklifEdilenNobet?.NobetTipi == "Bayram" ? "bg-info" : "bg-secondary") mt-1" style="font-size:0.7rem;">@teklif.TeklifEdilenNobet?.NobetTipi</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">
                                            <i class="fa-solid fa-user me-1 text-secondary"></i>
                                            @(teklif.HedefPersonel?.AdSoyad ?? "Herkese Açık")
                                        </span>
                                    </td>
                                    <td>
                                        @if (teklif.Durum == "Beklemede")
                                        {
                                            <span class="status-badge bg-warning bg-opacity-25 text-warning"><i class="fa-solid fa-clock me-1"></i>Beklemede</span>
                                        }
                                        else if (teklif.Durum == "Onaylandi")
                                        {
                                            <span class="status-badge bg-success bg-opacity-10 text-success"><i class="fa-solid fa-check me-1"></i>Anlaşıldı</span>
                                        }
                                        else if (teklif.Durum == "Reddedildi")
                                        {
                                            <span class="status-badge bg-danger bg-opacity-10 text-danger"><i class="fa-solid fa-xmark me-1"></i>Reddedildi</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge bg-light text-muted"><i class="fa-solid fa-ban me-1"></i>İptal</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@teklif.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end pe-4">
                                        @if (teklif.Durum == "Beklemede")
                                        {
                                            <form asp-action="Cancel" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@teklif.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm transition-all" onclick="return confirm('Bu teklifi iptal etmek istediğinize emin misiniz?')">
                                                    <i class="fa-solid fa-trash-can me-1"></i> İptal
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-paper-plane fs-1 opacity-25 d-block mb-3"></i>
                                    Henüz bir teklif göndermediniz.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>