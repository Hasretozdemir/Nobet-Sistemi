@{
    ViewData["Title"] = "Nöbet Takas Sistemi";
    var benimTekliflerim = ViewBag.BenimTekliflerim as List<HastaneNobetSistemi.Models.NobetTakas>;
    var banaGelenTeklifler = ViewBag.BanaGelenTeklifler as List<HastaneNobetSistemi.Models.NobetTakas>;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8f9fa;
    }

    .glass-header {
        background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .custom-card {
        border: none;
        border-radius: 16px;
        transition: transform 0.2s;
    }

        .custom-card:hover {
            transform: translateY(-3px);
        }

    .status-badge {
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s;
    }

    .table thead th {
        background-color: #f1f4f8;
        color: #4a5568;
        font-weight: 600;
        border: none;
        font-size: 0.85rem;
    }

    .incoming-offer {
        border-left: 5px solid #198754 !important;
    }
</style>

<div class="container py-5">
    <div class="glass-header p-5 mb-5 text-white d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="display-6 fw-bold mb-2">Nöbet Takas Merkezi</h1>
            <p class="opacity-75 mb-0"><i class="fa-solid fa-circle-info me-2"></i>Nöbetlerinizi yönetin, takas taleplerini hızlıca onaylayın.</p>
        </div>
        <a asp-action="Create" class="btn btn-light btn-lg rounded-pill px-4 fw-bold shadow">
            <i class="fa-solid fa-plus me-2 text-primary"></i>Yeni Takas Oluştur
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-12">
            <div class="card custom-card shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fa-solid fa-inbox me-2 text-success"></i>Bana Gelen Teklifler
                        </h5>
                        @if (banaGelenTeklifler?.Any() == true)
                        {
                            <span class="badge rounded-pill bg-danger">@banaGelenTeklifler.Count Yeni</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    @if (banaGelenTeklifler == null || !banaGelenTeklifler.Any())
                    {
                        <div class="text-center py-5">
                            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="80" class="opacity-25 mb-3">
                            <p class="text-muted">Şu an için bekleyen bir teklifiniz bulunmuyor.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var teklif in banaGelenTeklifler)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <div class="card h-100 border shadow-sm incoming-offer">
                                        <div class="card-body p-4">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-primary bg-opacity-10 p-2 rounded-circle me-3">
                                                    <i class="fa-solid fa-user-md text-primary fs-4"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@teklif.TeklifEdenPersonel.AdSoyad</h6>
                                                    <small class="text-muted">@teklif.OlusturmaTarihi.ToString("dd MMM, HH:mm")</small>
                                                </div>
                                            </div>
                                            <div class="bg-light rounded-3 p-3 mb-3">
                                                <div class="small text-muted mb-1">Takas Edilmek İstenen:</div>
                                                <div class="fw-bold fs-6">@teklif.TeklifEdilenNobet.Tarih.ToString("dd MMMM dddd")</div>
                                                <span class="badge bg-dark mt-2">@teklif.TeklifEdilenNobet.NobetTipi</span>
                                            </div>
                                            <p class="small text-secondary mb-4 italic">"@teklif.Aciklama"</p>
                                            <div class="d-flex gap-2">
                                                <a asp-action="Accept" asp-route-id="@teklif.Id" class="btn btn-success flex-grow-1 rounded-pill">
                                                    <i class="fa-solid fa-check me-1"></i> Onayla
                                                </a>
                                                <button class="btn btn-outline-danger flex-grow-1 rounded-pill" data-bs-toggle="modal" data-bs-target="#redModal-@teklif.Id">
                                                    <i class="fa-solid fa-xmark me-1"></i> Reddet
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <div class="card custom-card shadow-sm">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="fa-solid fa-paper-plane me-2 text-primary"></i>Gönderdiğim Teklifler
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-middle custom-table">
                            <thead>
                                <tr>
                                    <th>Nöbet Detayı</th>
                                    <th>Hedef Kişi</th>
                                    <th>Durum</th>
                                    <th>Tarih</th>
                                    <th class="text-end">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (benimTekliflerim != null && benimTekliflerim.Any())
                                {
                                    @foreach (var teklif in benimTekliflerim)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-dark">@teklif.TeklifEdilenNobet.Tarih.ToString("dd MMM yyyy")</div>
                                                <small class="text-muted">@teklif.TeklifEdilenNobet.NobetTipi</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border p-2">
                                                    <i class="fa-solid fa-user me-1 text-secondary"></i>
                                                    @(teklif.HedefPersonel?.AdSoyad ?? "Herkese Açık")
                                                </span>
                                            </td>
                                            <td>
                                                @if (teklif.Durum == "Beklemede")
                                                {
                                                    <span class="status-badge bg-warning text-dark">Beklemede</span>
                                                }
                                                else if (teklif.Durum == "Onaylandi")
                                                {

                                                    <span class="status-badge bg-success text-white">Tamamlandı</span>
                                                }
                                                else
                                                {

                                                    <span class="status-badge bg-light text-muted">@teklif.Durum</span>
                                                }
                                            </td>
                                            <td class="text-muted small">@teklif.OlusturmaTarihi.ToShortDateString()</td>
                                            <td class="text-end">
                                                @if (teklif.Durum == "Beklemede")
                                                {
                                                    <form asp-action="Cancel" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@teklif.Id" />
                                                        <button type="submit" class="btn btn-action btn-outline-danger shadow-sm" title="İptal Et" onclick="return confirm('Emin misiniz?')">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="5" class="text-center py-4 text-muted">Henüz bir teklif göndermediniz.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>