@model HastaneNobetSistemi.Models.Nobet

@{
    ViewData["Title"] = "Manuel Nöbet Ekle";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-header bg-primary text-white text-center py-4 rounded-top-4 position-relative overflow-hidden">
                <i class="fa-solid fa-notes-medical position-absolute top-50 start-50 translate-middle" style="font-size: 8rem; opacity: 0.1; z-index: 0;"></i>

                <div class="position-relative" style="z-index: 1;">
                    <h3 class="mb-0 fw-bold">
                        <i class="fa-solid fa-calendar-plus me-2"></i>Manuel Nöbet Ata
                    </h3>
                    <p class="text-white opacity-75 small mt-1 mb-0">Sisteme istisnai bir nöbet kaydı ekliyorsunuz.</p>
                </div>
            </div>

            <div class="card-body p-4 p-md-5 bg-white rounded-bottom-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold bg-danger bg-opacity-10 p-2 rounded"></div>

                    <div class="form-floating mb-4 shadow-sm">
                        <select asp-for="PersonelId" class="form-select fw-bold text-primary border-primary border-opacity-50" asp-items="ViewBag.PersonelId">
                            <option value="">-- Nöbetçi Personeli Seçiniz --</option>
                        </select>
                        <label asp-for="PersonelId">
                            <i class="fa-solid fa-user-doctor me-1 text-primary"></i> Personel Adı
                        </label>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Tarih" class="form-control" type="date" />
                        <label asp-for="Tarih">
                            <i class="fa-solid fa-calendar-day me-1 text-muted"></i> Nöbet Tarihi
                        </label>
                        <span asp-validation-for="Tarih" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-4">
                                <input asp-for="PuanDegeri" class="form-control" placeholder="Örn: 10" type="number" />
                                <label asp-for="PuanDegeri">
                                    <i class="fa-solid fa-star me-1 text-warning"></i> Nöbet Puanı
                                </label>
                                <span asp-validation-for="PuanDegeri" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-4">
                                <input asp-for="NobetTipi" class="form-control" placeholder="Örn: Hafta Sonu" autocomplete="off" />
                                <label asp-for="NobetTipi">
                                    <i class="fa-solid fa-layer-group me-1 text-muted"></i> Nöbet Tipi
                                </label>
                                <span asp-validation-for="NobetTipi" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 my-4" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-pill transition-hover">
                            <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                        </a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold rounded-pill shadow-sm transition-hover">
                            <i class="fa-solid fa-check-double me-2"></i>Nöbeti Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <style>
        .transition-hover {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .transition-hover:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.15) !important;
            }
    </style>
}