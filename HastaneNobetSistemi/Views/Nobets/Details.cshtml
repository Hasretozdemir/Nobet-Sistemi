@model HastaneNobetSistemi.Models.Nobet

@{
    ViewData["Title"] = "Nöbet Detayı";
    var gecmisTarih = Model.Tarih.Date < DateTime.Today;
    var bugunku = Model.Tarih.Date == DateTime.Today;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-7 col-lg-9">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-header bg-dark py-4 px-4 position-relative border-0">
                    <div class="d-flex align-items-center justify-content-between position-relative" style="z-index: 2;">
                        <div>
                            <h3 class="text-white mb-0 fw-bold">
                                <i class="fa-solid fa-clipboard-list me-2 text-info"></i>Nöbet Kayıt Detayı
                            </h3>
                            <p class="text-white-50 small mb-0 mt-1">Sistemde kayıtlı nöbetin tüm bilgileri.</p>
                        </div>
                        <div class="text-white-50 d-none d-sm-block">
                            <i class="fa-solid fa-file-medical fa-3x opacity-25"></i>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-light">

                    <!-- Durum Göstergesi -->
                    @if (bugunku)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4 shadow-sm border-0 rounded-3">
                            <i class="fa-solid fa-bell me-3 fs-4 pulse-icon"></i>
                            <div>
                                <strong>BUGÜN NÖBETÇİ!</strong>
                                <span class="text-muted ms-2">Bu personel bugün nöbet tutmaktadır.</span>
                            </div>
                        </div>
                    }
                    else if (gecmisTarih)
                    {
                        <div class="alert alert-success d-flex align-items-center mb-4 shadow-sm border-0 rounded-3">
                            <i class="fa-solid fa-circle-check me-3 fs-4"></i>
                            <div>
                                <strong>Tamamlandı</strong>
                                <span class="text-muted ms-2">Bu nöbet başarıyla tamamlanmıştır.</span>
                            </div>
                        </div>
                    }

                    <!-- Personel Bilgisi -->
                    <div class="d-flex align-items-center p-4 bg-white rounded-4 shadow-sm mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary fw-bold d-flex align-items-center justify-content-center rounded-circle me-4" style="width: 60px; height: 60px; font-size: 1.5rem;">
                            @(Model.Personel?.AdSoyad?.Substring(0, 1).ToUpper() ?? "?")
                        </div>
                        <div>
                            <small class="text-muted text-uppercase fw-bold">Nöbetçi Personel</small>
                            <h4 class="fw-bold text-dark mb-0">@Model.Personel?.AdSoyad</h4>
                        </div>
                    </div>

                    <!-- Detay Kartları -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-body p-4 text-center">
                                    <i class="fa-solid fa-calendar-day text-primary fs-3 mb-2"></i>
                                    <small class="d-block text-muted text-uppercase fw-bold mb-1">Nöbet Tarihi</small>
                                    <h5 class="fw-bold text-dark mb-1">@Model.Tarih.ToString("dd MMMM yyyy")</h5>
                                    <span class="text-muted">@Model.Tarih.ToString("dddd")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm rounded-4 h-100">
                                <div class="card-body p-4 text-center">
                                    @if (Model.NobetTipi == "HaftaIci")
                                    {
                                        <i class="fa-solid fa-building text-secondary fs-3 mb-2"></i>
                                        <small class="d-block text-muted text-uppercase fw-bold mb-1">Nöbet Tipi</small>
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-4 py-2 rounded-pill fs-6 fw-bold">Hafta İçi</span>
                                    }
                                    else if (Model.NobetTipi == "HaftaSonu")
                                    {
                                        <i class="fa-solid fa-mug-hot text-warning fs-3 mb-2"></i>
                                        <small class="d-block text-muted text-uppercase fw-bold mb-1">Nöbet Tipi</small>
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-4 py-2 rounded-pill fs-6 fw-bold">Hafta Sonu</span>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-star text-info fs-3 mb-2"></i>
                                        <small class="d-block text-muted text-uppercase fw-bold mb-1">Nöbet Tipi</small>
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-4 py-2 rounded-pill fs-6 fw-bold">Bayram</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Durum Kartı -->
                    <div class="card border-0 bg-white shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="row g-0 text-center">
                            <div class="col-4 p-3 border-end">
                                <small class="text-muted d-block">Kayıt No</small>
                                <span class="fw-bold text-dark fs-5">#@Model.Id</span>
                            </div>
                            <div class="col-4 p-3 border-end">
                                <small class="text-muted d-block">Durum</small>
                                @if (bugunku)
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-1">BUGÜN</span>
                                }
                                else if (gecmisTarih)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-1">Tamamlandı</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary rounded-pill px-3 py-1">Bekliyor</span>
                                }
                            </div>
                            <div class="col-4 p-3">
                                <small class="text-muted d-block">Kalan Gün</small>
                                @if (gecmisTarih)
                                {
                                    <span class="fw-bold text-success fs-6">Geçti</span>
                                }
                                else
                                {
                                    <span class="fw-bold text-primary fs-5">@((Model.Tarih.Date - DateTime.Today).Days)</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4 order-2 order-md-1">
                            <a asp-action="Index" class="btn btn-outline-dark w-100 py-3 rounded-pill fw-bold transition-all">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                        </div>
                        <div class="col-md-4 order-3 order-md-2">
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger w-100 py-3 rounded-pill fw-bold transition-all">
                                <i class="fa-solid fa-trash-can me-2"></i>Sil
                            </a>
                        </div>
                        <div class="col-md-4 order-1 order-md-3">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning w-100 py-3 rounded-pill fw-bold shadow transition-all text-dark">
                                <i class="fa-solid fa-pen-to-square me-2"></i>Düzenle
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .transition-all {
            transition: all 0.3s ease;
        }
            .transition-all:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            }
        .pulse-icon {
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
    </style>
}