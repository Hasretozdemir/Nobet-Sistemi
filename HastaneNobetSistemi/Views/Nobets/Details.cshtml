@model HastaneNobetSistemi.Models.Nobet

@{
    ViewData["Title"] = "Nöbet Detayları";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

            <div class="card-header bg-primary text-white text-center py-4 border-0 position-relative">
                <i class="fa-solid fa-clipboard-user fa-3x mb-2 opacity-75"></i>
                <h3 class="mb-0 fw-bold">Nöbet Kayıt Detayı</h3>
                <p class="text-white opacity-75 small mt-1 mb-0">Sistemde kayıtlı nöbetin tüm bilgileri.</p>
            </div>

            <div class="card-body p-4 p-md-5 bg-white">

                <ul class="list-group list-group-flush fs-5 mb-4">

                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-user-doctor me-2 text-primary"></i>@Html.DisplayNameFor(model => model.Personel)
                        </span>
                        <span class="fw-bold text-primary fs-5 text-end">
                            @Html.DisplayFor(model => model.Personel.AdSoyad)
                        </span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-calendar-day me-2 text-primary"></i>@Html.DisplayNameFor(model => model.Tarih)
                        </span>
                        <span class="fw-bold text-dark text-end">
                            @Html.DisplayFor(model => model.Tarih)
                        </span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-star me-2 text-warning"></i>@Html.DisplayNameFor(model => model.PuanDegeri)
                        </span>
                        <span class="text-end">
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fs-6 shadow-sm">
                                @Html.DisplayFor(model => model.PuanDegeri) Puan
                            </span>
                        </span>
                    </li>

                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 border-bottom">
                        <span class="text-muted fw-semibold">
                            <i class="fa-solid fa-layer-group me-2 text-info"></i>@Html.DisplayNameFor(model => model.NobetTipi)
                        </span>
                        <span class="text-end">
                            <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fs-6 fw-medium">
                                @Html.DisplayFor(model => model.NobetTipi)
                            </span>
                        </span>
                    </li>
                </ul>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-pill transition-hover">
                        <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-5 py-2 fw-bold rounded-pill shadow-sm text-dark transition-hover">
                        <i class="fa-solid fa-pen-to-square me-2"></i>Düzenle
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .transition-hover {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .transition-hover:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
            }
    </style>
}