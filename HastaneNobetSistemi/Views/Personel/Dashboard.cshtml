@{
    ViewData["Title"] = "Personel Paneli";
    var personel = ViewBag.Personel as HastaneNobetSistemi.Models.Personel;
    var gelecekNobetler = ViewBag.GelecekNobetler as List<HastaneNobetSistemi.Models.Nobet>;
    var gecmisNobetler = ViewBag.GecmisNobetler as List<HastaneNobetSistemi.Models.Nobet>;
    var bekleyenIzinTalepleri = ViewBag.BekleyenIzinTalepleri as int? ?? 0;
    var bekleyenTakaslar = ViewBag.BekleyenTakaslar as int? ?? 0;
    var onaylananIzinler = ViewBag.OnaylananIzinler as List<HastaneNobetSistemi.Models.IzinTalebi>;
    var toplamKazanc = ViewBag.ToplamKazanc as decimal? ?? 0;
    var buAyKazanc = ViewBag.BuAyKazanc as decimal? ?? 0;
    var nobetBasinaUcret = ViewBag.NobetBasinaUcret as decimal? ?? 0;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #f4f7fe;
        font-family: 'Inter', sans-serif;
        color: #2d3748;
    }

    /* Üst Karşılama Alanı */
    .welcome-banner {
        background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
        border-radius: 24px;
        box-shadow: 0 10px 25px rgba(67, 97, 238, 0.15);
    }

    /* Kart Tasarımları */
    .custom-card {
        border: none;
        border-radius: 20px;
        transition: transform 0.2s, box-shadow 0.2s;
        background: #fff;
    }

        .custom-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 20px rgba(0,0,0,0.05);
        }

    /* Hızlı İşlem İkonları */
    .action-icon {
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        margin: 0 auto 12px;
        font-size: 1.5rem;
    }

    /* Bildirim Badge */
    .badge-notif {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 5px 8px;
        font-size: 0.75rem;
        border: 2px solid #fff;
    }

    /* Liste Tasarımı */
    .nobet-item {
        border-left: 4px solid transparent;
        transition: all 0.2s;
        border-radius: 12px;
        margin-bottom: 8px;
        background: #f8fafc;
    }

        .nobet-item:hover {
            background: #f1f5f9;
            border-left-color: #4361ee;
        }

    .nobet-today {
        border-left-color: #e63946;
        background: #fff1f2 !important;
    }

    /* İstatistikler */
    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a202c;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #718096;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Linkler */
    .alert-link-custom {
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
    }
</style>

<div class="container py-4">

    <!-- SİSTEM BİLDİRİMLERİ -->
    @if (ViewContext.HttpContext.Request.Cookies["dismissedDevNoticePersonel"] == null)
    {
        <div class="alert border-0 shadow-sm rounded-4 mb-4 p-0 overflow-hidden" id="devNoticeAlert" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);">
            <div class="d-flex align-items-start p-4">
                <div class="me-3 mt-1">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width:44px;height:44px;background:rgba(245,158,11,0.2);">
                        <i class="fa-solid fa-triangle-exclamation text-warning fs-5"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-1" style="font-size:0.85rem;"><i class="fa-solid fa-code me-1"></i>Önemli Bilgilendirme</h6>
                    <p class="text-dark mb-2" style="font-size: 0.78rem; line-height: 1.7;">
                        Bu nöbet sistemi <strong>yeni mezun bir geliştirici</strong> tarafından yapılmıştır ve geliştirme süreci devam etmektedir.
                        Nöbet listelerinizi <strong>kontrollü bir şekilde</strong> takip ediniz.
                        Bir hata fark ettiğinizde veya öneriniz olduğunda lütfen
                        <a asp-controller="Home" asp-action="Iletisim" class="fw-bold text-warning text-decoration-underline">İletişim</a>
                        sayfasından bize ulaşın.
                    </p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Home" asp-action="Iletisim" class="btn btn-sm btn-warning rounded-pill px-3 fw-bold shadow-sm" style="font-size:0.75rem;">
                            <i class="fa-solid fa-envelope me-1"></i> İletişime Geç
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-dark rounded-pill px-3" style="font-size:0.75rem;" onclick="dismissPersonelNotice('devNotice')">
                            <i class="fa-solid fa-check me-1"></i> Anladım
                        </button>
                    </div>
                </div>
                <button type="button" class="btn-close ms-2" style="font-size:0.6rem;" onclick="dismissPersonelNotice('devNotice')"></button>
            </div>
        </div>
    }

    @if (ViewContext.HttpContext.Request.Cookies["dismissedSystemInfoPersonel"] == null)
    {
        <div class="alert border-0 shadow-sm rounded-4 mb-4 p-0 overflow-hidden" id="systemInfoAlert" style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);">
            <div class="d-flex align-items-start p-4">
                <div class="me-3 mt-1">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width:44px;height:44px;background:rgba(59,130,246,0.15);">
                        <i class="fa-solid fa-circle-info text-primary fs-5"></i>
                    </div>
                </div>
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-1" style="font-size:0.85rem;"><i class="fa-solid fa-laptop-medical me-1"></i>Nöbet Sistemi Rehberi</h6>
                    <p class="text-dark mb-2" style="font-size: 0.78rem; line-height: 1.7;">
                        Bu panel üzerinden <strong>nöbet listenizi</strong> görüntüleyebilir, <strong>izin talebi</strong> oluşturabilir,
                        <strong>nöbet takası</strong> teklif edebilir ve geçmiş nöbet istatistiklerinizi inceleyebilirsiniz.
                        Takas işlemleri resmi nöbet listesini <strong>etkilemez</strong>, sadece kendi aranızda anlaşma kaydı tutulur.
                    </p>
                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" style="font-size:0.75rem;" onclick="dismissPersonelNotice('systemInfo')">
                        <i class="fa-solid fa-check me-1"></i> Anladım
                    </button>
                </div>
                <button type="button" class="btn-close ms-2" style="font-size:0.6rem;" onclick="dismissPersonelNotice('systemInfo')"></button>
            </div>
        </div>
    }

    <div class="welcome-banner p-4 p-md-5 mb-5 text-white position-relative overflow-hidden">
        <div class="row align-items-center position-relative" style="z-index: 2;">
            <div class="col-md-8">
                <h2 class="fw-bold mb-2">Tekrar Merhaba, @(personel.AdSoyad.Split(' ')[0])!</h2>
                <p class="opacity-75 mb-0 d-flex align-items-center">
                    <i class="fa-solid fa-hospital-user me-2"></i> @personel.Birim Bölümü Personeli
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <div class="bg-white bg-opacity-20 d-inline-block p-3 rounded-4 backdrop-blur">
                    <small class="d-block opacity-75">Sistem Tarihi</small>
                    <span class="fw-bold fs-5">@DateTime.Now.ToString("dd MMMM yyyy")</span>
                </div>
            </div>
        </div>
        <i class="fa-solid fa-stethoscope position-absolute opacity-10" style="font-size: 150px; right: -20px; bottom: -30px;"></i>
    </div>

    <div class="row">
        <div class="col-lg-8">

            @if (bekleyenTakaslar > 0 || bekleyenIzinTalepleri > 0 || onaylananIzinler?.Any() == true)
            {
                <div class="card custom-card shadow-sm mb-4 border-0">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-bell-concierge me-2 text-primary"></i>Güncel Durum</h6>

                        @if (bekleyenTakaslar > 0)
                        {
                            <div class="d-flex align-items-center p-3 rounded-4 bg-warning bg-opacity-10 mb-2">
                                <i class="fa-solid fa-arrows-rotate text-warning fs-4 me-3"></i>
                                <div class="flex-grow-1">
                                    <span class="d-block fw-bold text-dark">Takas Onayı Bekliyor</span>
                                    <small class="text-muted">@bekleyenTakaslar adet yeni talep var.</small>
                                </div>
                                <a asp-controller="NobetTakas" asp-action="Index" class="btn btn-sm btn-warning rounded-pill px-3 fw-bold">İncele</a>
                            </div>
                        }

                        @if (onaylananIzinler?.Any() == true)
                        {
                            @foreach (var izin in onaylananIzinler.Take(1))
                            {
                                <div class="d-flex align-items-center p-3 rounded-4 bg-success bg-opacity-10">
                                    <i class="fa-solid fa-umbrella-beach text-success fs-4 me-3"></i>
                                    <div class="flex-grow-1">
                                        <span class="d-block fw-bold text-dark">Yaklaşan İzniniz</span>
                                        <small class="text-muted">@izin.BaslangicTarihi.ToString("dd MMM") - @izin.BitisTarihi.ToString("dd MMM") tarihleri arası.</small>
                                    </div>
                                    <span class="badge bg-success rounded-pill px-3">Onaylandı</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            <div class="row mb-4 g-3 text-center">
                <div class="col-6 col-md-3">
                    <a asp-action="NobetListesi" class="card custom-card shadow-sm p-3 text-decoration-none h-100">
                        <div class="action-icon bg-primary bg-opacity-10 text-primary">
                            <i class="fa-solid fa-calendar-days"></i>
                        </div>
                        <span class="d-block fw-bold text-dark small">Nöbet Listesi</span>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="Izin" asp-action="TalepOlustur" class="card custom-card shadow-sm p-3 text-decoration-none h-100 position-relative">
                        <div class="action-icon bg-warning bg-opacity-10 text-warning">
                            <i class="fa-solid fa-paper-plane"></i>
                        </div>
                        <span class="d-block fw-bold text-dark small">İzin Talebi</span>
                        @if (bekleyenIzinTalepleri > 0)
                        {
                            <span class="badge rounded-pill bg-danger badge-notif">@bekleyenIzinTalepleri</span>
                        }
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="NobetTakas" asp-action="Index" class="card custom-card shadow-sm p-3 text-decoration-none h-100 position-relative">
                        <div class="action-icon bg-info bg-opacity-10 text-info">
                            <i class="fa-solid fa-arrows-left-right"></i>
                        </div>
                        <span class="d-block fw-bold text-dark small">Nöbet Takası</span>
                        @if (bekleyenTakaslar > 0)
                        {
                            <span class="badge rounded-pill bg-danger badge-notif">@bekleyenTakaslar</span>
                        }
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-action="NobetGecmisim" class="card custom-card shadow-sm p-3 text-decoration-none h-100">
                        <div class="action-icon bg-success bg-opacity-10 text-success">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                        </div>
                        <span class="d-block fw-bold text-dark small">Nöbet Geçmişi</span>
                    </a>
                </div>
            </div>

            <div class="card custom-card shadow-sm border-0 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0 text-dark">Gelecek Nöbetlerim</h6>
                    <a asp-action="NobetListesi" class="small alert-link-custom text-primary">Tümünü Gör</a>
                </div>
                <div class="card-body p-4">
                    @if (gelecekNobetler?.Any() != true)
                    {
                        <div class="text-center py-4">
                            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="60" class="opacity-25 mb-3">
                            <p class="text-muted small">Planlanmış bir nöbetiniz bulunmuyor.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var nobet in gelecekNobetler.Take(4))
                        {
                            var bugunku = nobet.Tarih.Date == DateTime.Today;
                            <div class="p-3 nobet-item d-flex justify-content-between align-items-center @(bugunku ? "nobet-today" : "")">
                                <div class="d-flex align-items-center">
                                    <div class="text-center me-3 border-end pe-3">
                                        <span class="d-block fw-bold fs-5">@nobet.Tarih.Day</span>
                                        <small class="text-muted uppercase">@nobet.Tarih.ToString("MMM")</small>
                                    </div>
                                    <div>
                                        <span class="fw-bold d-block text-dark">@nobet.Tarih.ToString("dddd")</span>
                                        <span class="badge @(nobet.NobetTipi == "HaftaIci" ? "bg-secondary" : "bg-warning text-dark") rounded-pill" style="font-size: 0.65rem;">
                                            @nobet.NobetTipi
                                        </span>
                                    </div>
                                </div>
                                @if (bugunku)
                                {
                                    <span class="badge bg-danger rounded-pill px-3">BUGÜN</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card custom-card shadow-sm mb-4 border-0">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary bg-opacity-10 p-4 rounded-circle d-inline-block mb-3">
                        <i class="fa-solid fa-user-doctor fs-1 text-primary"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@personel.AdSoyad</h5>
                    <p class="text-muted small mb-1">@personel.SicilNo | @personel.Birim</p>
                    @if (!string.IsNullOrEmpty(personel.Unvan))
                    {
                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1 mb-3"><i class="fa-solid fa-briefcase me-1"></i>@personel.Unvan</span>
                    }
                    <hr>
                    <div class="row">
                        <div class="col-6 border-end">
                            <span class="stat-label d-block">Hafta İçi</span>
                            <span class="stat-value">@personel.ToplamHaftaIci</span>
                        </div>
                        <div class="col-6">
                            <span class="stat-label d-block">Hafta Sonu</span>
                            <span class="stat-value">@personel.ToplamHaftaSonu</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card custom-card shadow-sm border-0 bg-dark text-white p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="stat-label d-block text-white-50">Toplam Nöbet</span>
                        <h2 class="fw-bold mb-0">@(personel.ToplamHaftaIci + personel.ToplamHaftaSonu + personel.ToplamBayram)</h2>
                    </div>
                    <div class="bg-white bg-opacity-20 p-3 rounded-4">
                        <i class="fa-solid fa-chart-pie fs-3 text-white"></i>
                    </div>
                </div>
            </div>

            @if (nobetBasinaUcret > 0)
            {
                <div class="card custom-card shadow-sm border-0 overflow-hidden mb-4" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-white bg-opacity-20 p-2 rounded-3 me-3">
                                <i class="fa-solid fa-turkish-lira-sign fs-4"></i>
                            </div>
                            <div>
                                <span class="small text-white-50 d-block">Nöbet Ücret Bilgisi</span>
                                @if (personel.UcretTipi == "IcapUzaktan")
                                {
                                    <span class="fw-bold">@nobetBasinaUcret.ToString("N2") ₺ / nöbet</span>
                                    <span class="badge bg-white bg-opacity-20 rounded-pill px-2 py-1 ms-1" style="font-size:0.65rem;">İcap+Uzaktan</span>
                                }
                                else
                                {
                                    <span class="fw-bold">@nobetBasinaUcret.ToString("N2") ₺ / nöbet</span>
                                }
                            </div>
                        </div>
                        @if (personel.UcretTipi == "IcapUzaktan")
                        {
                            <div class="bg-white bg-opacity-10 rounded-3 p-2 mb-3" style="font-size:0.75rem;">
                                <div class="d-flex justify-content-between mb-1">
                                    <span><i class="fa-solid fa-phone-volume me-1"></i>İcap: @personel.IcapSaatlikUcret.ToString("N2") ₺ × @personel.IcapSaat saat</span>
                                    <span class="fw-bold">@((personel.IcapSaatlikUcret * personel.IcapSaat).ToString("N2")) ₺</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span><i class="fa-solid fa-laptop me-1"></i>Uzaktan: @personel.UzaktanSaatlikUcret.ToString("N2") ₺ × @personel.UzaktanSaat saat</span>
                                    <span class="fw-bold">@((personel.UzaktanSaatlikUcret * personel.UzaktanSaat).ToString("N2")) ₺</span>
                                </div>
                            </div>
                        }
                        <hr class="opacity-25">
                        <div class="row text-center">
                            <div class="col-6 border-end border-white border-opacity-25">
                                <small class="d-block text-white-50">Bu Ay</small>
                                <h4 class="fw-bold mb-0">@buAyKazanc.ToString("N2") ₺</h4>
                            </div>
                            <div class="col-6">
                                <small class="d-block text-white-50">Toplam Kazanç</small>
                                <h4 class="fw-bold mb-0">@toplamKazanc.ToString("N2") ₺</h4>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function dismissPersonelNotice(type) {
            var cookieName = 'dismissed' + type.charAt(0).toUpperCase() + type.slice(1) + 'Personel';
            document.cookie = cookieName + "=true; path=/; max-age=" + (30 * 24 * 60 * 60);
            var alertId = type === 'devNotice' ? 'devNoticeAlert' : 'systemInfoAlert';
            var el = document.getElementById(alertId);
            if (el) {
                el.style.transition = 'opacity 0.3s, transform 0.3s';
                el.style.opacity = '0';
                el.style.transform = 'translateY(-10px)';
                setTimeout(function () { el.remove(); }, 300);
            }
        }
    </script>
}