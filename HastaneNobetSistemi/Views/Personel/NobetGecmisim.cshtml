@model IEnumerable<HastaneNobetSistemi.Models.Nobet>

@{
    ViewData["Title"] = "Nöbet Geçmişim";
    var personel = ViewBag.Personel as HastaneNobetSistemi.Models.Personel;
    var stats = ViewBag.Stats;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #f4f7fe;
        font-family: 'Inter', sans-serif;
    }

    h2, h3, h5 {
        font-family: 'Poppins', sans-serif;
    }

    /* Sayfa Başlığı */
    .page-title-box {
        padding: 20px 0;
        margin-bottom: 30px;
    }

    /* İstatistik Kartları */
    .stat-card-custom {
        background: white;
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        height: 100%;
    }

        .stat-card-custom:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        }

    .stat-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 1.25rem;
    }

    /* Tablo Alanı */
    .history-card {
        background: white;
        border-radius: 25px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .table thead th {
        background: #f8fafc;
        color: #64748b;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 1.2rem 1rem;
        border: none;
    }

    /* Durum Badge'leri */
    .badge-pill-soft {
        padding: 8px 14px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.75rem;
    }
</style>

<div class="container py-4">

    <div class="page-title-box d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1 text-dark"><i class="fa-solid fa-history text-primary me-2"></i>Nöbet Geçmişim</h2>
            <p class="text-muted mb-0">@(personel?.AdSoyad) - Toplam Çalışma İstatistikleri</p>
        </div>
        <button onclick="window.print()" class="btn btn-outline-secondary rounded-pill px-4 bg-white shadow-sm">
            <i class="fa-solid fa-print me-2"></i>Rapor Al
        </button>
    </div>

    <div class="row mb-5 g-3 text-center">
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card-custom p-3 border-bottom border-primary border-4">
                <div class="stat-icon-wrapper bg-primary bg-opacity-10 text-primary">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                <h3 class="fw-bold mb-0">@stats.ToplamNobet</h3>
                <small class="text-muted fw-medium">Toplam</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card-custom p-3">
                <div class="stat-icon-wrapper bg-secondary bg-opacity-10 text-secondary">
                    <i class="fa-solid fa-calendar-day"></i>
                </div>
                <h3 class="fw-bold mb-0">@stats.ToplamHaftaIci</h3>
                <small class="text-muted fw-medium">Hafta İçi</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card-custom p-3">
                <div class="stat-icon-wrapper bg-warning bg-opacity-10 text-warning">
                    <i class="fa-solid fa-mug-hot"></i>
                </div>
                <h3 class="fw-bold mb-0">@stats.ToplamHaftaSonu</h3>
                <small class="text-muted fw-medium">Hafta Sonu</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card-custom p-3">
                <div class="stat-icon-wrapper bg-info bg-opacity-10 text-info">
                    <i class="fa-solid fa-star"></i>
                </div>
                <h3 class="fw-bold mb-0">@stats.ToplamBayram</h3>
                <small class="text-muted fw-medium">Bayram</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card-custom p-3">
                <div class="stat-icon-wrapper bg-success bg-opacity-10 text-success">
                    <i class="fa-solid fa-check-double"></i>
                </div>
                <h3 class="fw-bold mb-0">@stats.TamamlananNobet</h3>
                <small class="text-muted fw-medium">Tamamlanan</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card-custom p-3 bg-primary text-white">
                <div class="stat-icon-wrapper bg-white bg-opacity-20 text-white">
                    <i class="fa-solid fa-hourglass-start"></i>
                </div>
                <h3 class="fw-bold mb-0">@stats.GelecekNobet</h3>
                <small class="text-white text-opacity-75 fw-medium">Bekleyen</small>
            </div>
        </div>
    </div>

    @if (stats.NobetBasinaUcret > 0)
    {
        <div class="row mb-5 g-3">
            <div class="col-md-4">
                <div class="card stat-card-custom p-4 border-start border-4 border-success">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon-wrapper bg-success bg-opacity-10 text-success me-3" style="margin: 0;">
                            <i class="fa-solid fa-turkish-lira-sign"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold text-uppercase">Nöbet Başına</small>
                            <h4 class="fw-bold text-success mb-0">@stats.NobetBasinaUcret.ToString("N2") ₺</h4>
                            @if (personel?.UcretTipi == "IcapUzaktan")
                            {
                                <small class="text-muted d-block" style="font-size:0.7rem;">
                                    <i class="fa-solid fa-phone-volume me-1"></i>@personel.IcapSaatlikUcret.ToString("N2")₺×@personel.IcapSaat sa +
                                    <i class="fa-solid fa-laptop ms-1 me-1"></i>@personel.UzaktanSaatlikUcret.ToString("N2")₺×@personel.UzaktanSaat sa
                                </small>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card-custom p-4 border-start border-4 border-warning">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon-wrapper bg-warning bg-opacity-10 text-warning me-3" style="margin: 0;">
                            <i class="fa-solid fa-coins"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold text-uppercase">Tamamlanan Kazanç</small>
                            <h4 class="fw-bold text-warning mb-0">@stats.TamamlananKazanc.ToString("N2") ₺</h4>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 border-0 rounded-4 text-white" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); box-shadow: 0 10px 25px rgba(17, 153, 142, 0.2);">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-20 p-2 rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-sack-dollar fs-4"></i>
                        </div>
                        <div>
                            <small class="text-white-50 fw-bold text-uppercase">Toplam Kazanç</small>
                            <h4 class="fw-bold mb-0">@stats.ToplamKazanc.ToString("N2") ₺</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="history-card">
        <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fa-solid fa-table-list me-2 text-primary"></i>Nöbet Hareketleri</h5>
            <span class="text-muted small">Toplam @Model.Count() Kayıt</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Tarih</th>
                        <th>Gün</th>
                        <th>Nöbet Türü</th>
                        <th>Ücret</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var nobet in Model.OrderByDescending(n => n.Tarih))
                    {
                        var gecmisTarih = nobet.Tarih.Date < DateTime.Today;
                        var bugunku = nobet.Tarih.Date == DateTime.Today;

                        <tr class="@(bugunku ? "bg-warning bg-opacity-10" : "")">
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark">@nobet.Tarih.ToString("dd MMMM yyyy")</div>
                            </td>
                            <td>
                                <span class="text-secondary fw-medium">@nobet.Tarih.ToString("dddd")</span>
                            </td>
                            <td>
                                @if (nobet.NobetTipi == "HaftaIci")
                                {
                                    <span class="badge bg-light text-secondary border px-3">Hafta İçi</span>
                                }
                                else if (nobet.NobetTipi == "HaftaSonu")
                                {

                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3">Hafta Sonu</span>
                                }
                                else
                                {

                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3">Bayram</span>
                                }
                            </td>
                            <td>
                                @if (stats.NobetBasinaUcret > 0)
                                {
                                    <span class="fw-bold text-success">@stats.NobetBasinaUcret.ToString("N2") ₺</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (gecmisTarih)
                                {
                                    <span class="badge-pill-soft bg-success bg-opacity-10 text-success">
                                        <i class="fa-solid fa-check-circle me-1"></i>Tamamlandı
                                    </span>
                                }
                                else if (bugunku)
                                {
                                    <span class="badge-pill-soft bg-danger text-white shadow-sm">
                                        <i class="fa-solid fa-bell me-1"></i>BUGÜN
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-pill-soft bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                        <i class="fa-regular fa-calendar-plus me-1"></i>Gelecek
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>