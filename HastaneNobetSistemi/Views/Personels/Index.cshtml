@model IEnumerable<HastaneNobetSistemi.Models.Personel>

@{
    ViewData["Title"] = "Personel Listesi";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fa-solid fa-user-group text-primary me-2"></i>Personel Yönetimi</h2>
            <p class="text-muted small mb-0">Adil nöbet dağıtımı için personellerin mevcut istatistikleri ve durumları.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Nobets" asp-action="ZorunluListe" class="btn btn-warning rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-shield-halved me-2"></i>Zorunlu Liste
            </a>
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-user-plus me-2"></i>Yeni Personel
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 text-muted small fw-bold text-uppercase">Personel Bilgisi</th>
                        <th class="text-center text-muted small fw-bold text-uppercase">Toplam H.İçi</th>
                        <th class="text-center text-muted small fw-bold text-uppercase">Toplam H.Sonu</th>
                        <th class="text-center text-muted small fw-bold text-uppercase">Toplam Bayram</th>
                        <th class="text-center text-muted small fw-bold text-uppercase">Nöbet Ücreti</th>
                        <th class="text-center text-muted small fw-bold text-uppercase">Sistem Durumu</th>
                        <th class="text-end pe-4 text-muted small fw-bold text-uppercase">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-users-slash fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                Henüz kayıtlı personel bulunmamaktadır.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        // İzin kontrolü
                        bool izinliMi = item.IzinBaslangic.HasValue && item.IzinBitis.HasValue &&
                        DateTime.Now.Date >= item.IzinBaslangic.Value.Date &&
                        DateTime.Now.Date <= item.IzinBitis.Value.Date;

                        var toplamNobet = item.ToplamHaftaIci + item.ToplamHaftaSonu + item.ToplamBayram;
                        var toplamUcret = toplamNobet * item.NobetUcreti;

                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle bg-light text-primary fw-bold me-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; border-radius: 50%;">
                                        @(string.IsNullOrEmpty(item.AdSoyad) ? "?" : item.AdSoyad.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6">
                                            @item.AdSoyad
                                            @if (item.ZorunluNobetciMi)
                                            {
                                                <span class="badge bg-warning bg-opacity-25 text-warning border border-warning border-opacity-50 rounded-pill px-2 py-1 ms-2">
                                                    <i class="fa-solid fa-shield-halved me-1"></i>ZORUNLU
                                                </span>
                                            }
                                        </div>
                                        <div class="small text-muted">
                                            @if (!string.IsNullOrEmpty(item.Unvan))
                                            {
                                                <span class="me-2"><i class="fa-solid fa-briefcase me-1"></i>@item.Unvan</span>
                                            }
                                            Son: @(item.SonNobetTarihi?.ToString("dd.MM.yyyy") ?? "Yok")
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-dark text-dark px-3 py-2 rounded-pill fs-6 border">@item.ToplamHaftaIci</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-warning text-dark px-3 py-2 rounded-pill fs-6 border">@item.ToplamHaftaSonu</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-info text-dark px-3 py-2 rounded-pill fs-6 border">@item.ToplamBayram</span>
                            </td>
                            <td class="text-center">
                                @{
                                    var nobetBasinaUcret = item.UcretTipi == "IcapUzaktan"
                                        ? (item.IcapSaatlikUcret * item.IcapSaat) + (item.UzaktanSaatlikUcret * item.UzaktanSaat)
                                        : item.NobetUcreti;
                                    var toplamUcretHesap = toplamNobet * nobetBasinaUcret;
                                }
                                @if (nobetBasinaUcret > 0)
                                {
                                    <div>
                                        <span class="badge bg-soft-success text-dark px-3 py-2 rounded-pill fs-6 border">@toplamUcretHesap.ToString("N2") ₺</span>
                                    </div>
                                    @if (item.UcretTipi == "IcapUzaktan")
                                    {
                                        <small class="text-muted">@nobetBasinaUcret.ToString("N2") ₺/nöbet <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25" style="font-size:0.6rem;">İcap+Uzaktan</span></small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">@nobetBasinaUcret.ToString("N2") ₺/nöbet</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Belirlenmedi</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (izinliMi)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-1"><i class="fa-solid fa-plane-departure me-1"></i> İZİNLİ</span>
                                }
                                else if (item.AktifMi == true || item.AktifMi == null)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1"><i class="fa-solid fa-circle-check me-1"></i> AKTİF</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-1"><i class="fa-solid fa-circle-minus me-1"></i> PASİF</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-1 justify-content-end">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-primary transition-hover" title="Düzenle">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-info transition-hover" title="Detaylar">
                                            <i class="fa-solid fa-circle-info"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-danger transition-hover" title="Sil">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    </div>
                                    <form asp-controller="Nobets" asp-action="ZorunluDurumDegistir" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="zorunluMu" value="@(!item.ZorunluNobetciMi)" />
                                        @if (item.ZorunluNobetciMi)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-warning shadow-sm transition-hover" title="Zorunlu Listeden Çıkar">
                                                <i class="fa-solid fa-shield-xmark"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-warning shadow-sm transition-hover" title="Zorunlu Listeye Ekle">
                                                <i class="fa-solid fa-shield-plus"></i>
                                            </button>
                                        }
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .bg-soft-dark {
            background-color: #f8f9fa;
        }

        .bg-soft-warning {
            background-color: #fff8e1;
            border-color: #ffe082 !important;
        }

        .bg-soft-info {
            background-color: #e1f5fe;
            border-color: #81d4fa !important;
        }

        .bg-soft-success {
            background-color: #e8f5e9;
            border-color: #a5d6a7 !important;
        }

        .transition-hover {
            transition: all 0.2s ease;
        }

            .transition-hover:hover {
                background-color: #f1f3f5;
                transform: translateY(-2px);
            }
    </style>
}